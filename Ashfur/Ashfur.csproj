        <PackageReference Include="NetCord.Services" Version="1.0.0-alpha.468"/>
        <PackageReference Include="osu.NET" Version="0.15.0" />
        <PackageReference Include="Sentry" Version="6.1.0" />
        <PackageReference Include="Sentry.Extensions.Logging" Version="6.1.0" />
        <PackageReference Include="Sentry.Profiling" Version="6.1.0" />
        <PackageReference Include="Sentry.Serilog" Version="6.1.0" />
        <PackageReference Include="Serilog" Version="4.3.1" />
        <PackageReference Include="Serilog.Enrichers.AssemblyName" Version="2.0.0" />
